local function createOnScreenButton(remote, name, optId)
    local guiName = "CustomRemoteButtonsGui"
    local gui = game:GetService("CoreGui"):FindFirstChild(guiName) or Instance.new("ScreenGui", game:GetService("CoreGui"))
    gui.Name = guiName

    local btn = Instance.new("TextButton")
    btn.Name = name .. "_Float"
    btn.Text = "  " .. name .. "  "
    btn.Size = UDim2.new(0, 0, 0, 30)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Position = UDim2.new(0, math.random(100, 300), 0, math.random(100, 300))
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    btn.Parent = gui

    -- ใส่ขอบมนและความสวยงาม
    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 1

    -- ทำให้ลากได้
    pcall(function() MakeDraggable(btn) end)

    -- ฟังก์ชันเมื่อกดปุ่ม (หัวใจสำคัญที่ต้องแก้)
    btn.MouseButton1Click:Connect(function()
        -- ดึงจำนวนจากช่อง Input ล่าสุด (ถ้าไม่มีให้ใช้ 1)
        local amt = 1
        if optId and Options[optId] then
            amt = tonumber(Options[optId].Value) or 1
        elseif savedAmounts and savedAmounts[name] then
            amt = tonumber(savedAmounts[name]) or 1
        end

        -- รัน Remote
        for i = 1, amt do
            task.spawn(function()
                pcall(function() remote:FireServer() end)
            end)
        end
        
        -- Effect ตอนกด (กระพริบ)
        btn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        task.wait(0.1)
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end)
    
    -- คลิกขวาเพื่อลบปุ่ม
    btn.MouseButton2Click:Connect(function()
        btn:Destroy()
    end)
end

-- 2. สร้างปุ่ม Float แบบ Toggle (วนลูป)
local function createOnScreenToggle(remote, remoteDisplayName)
    local guiName = "CustomFloatTogglesGui"
    local gui = CoreGui:FindFirstChild(guiName) or Instance.new("ScreenGui", CoreGui)
    gui.Name = guiName

    local btn = Instance.new("TextButton")
    btn.Name = remote.Name .. "_Toggle_" .. math.random(1, 10000)
    btn.Text = "  " .. remote.Name .. " [OFF]  " 
    btn.Size = UDim2.new(0, 0, 0, 25)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Position = UDim2.new(0, math.random(50, 250), 0, math.random(50, 250))
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- ค่าเริ่มต้น: พื้นดำ
    btn.TextColor3 = Color3.fromRGB(255, 255, 255) -- ค่าเริ่มต้น: อักษรขาว
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.Parent = gui
    MakeDraggable(btn)

    local isToggled = false
    btn.MouseButton1Click:Connect(function()
        isToggled = not isToggled
        
        -- ตอน OFF สีดำอักษรขาว, ตอน ON สีขาวอักษรดำ ตามสั่ง
        btn.Text = isToggled and ("  " .. remote.Name .. " [ON]  ") or ("  " .. remote.Name .. " [OFF]  ")
        btn.BackgroundColor3 = isToggled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 0, 0)
        btn.TextColor3 = isToggled and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)

        if isToggled then
            task.spawn(function()
                while isToggled do
                    local waitTime = tonumber(savedWaits[remoteDisplayName]) or 1
                    local amount = tonumber(savedAmounts[remoteDisplayName]) or 1
                    for i = 1, amount do
                        remote:FireServer()
                    end
                    task.wait(waitTime)
                end
            end)
        end
    end)
end

