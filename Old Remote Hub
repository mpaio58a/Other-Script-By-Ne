local function SetUIElementVisibility(element, isVisible)
    pcall(function()
        -- เจาะเข้าถึง Frame ด้านในของ LinoriaLib เพื่อซ่อนให้ชัวร์ที่สุด
        if type(element) == "table" then
            if element.Container then element.Container.Visible = isVisible end
            if element.Main then element.Main.Visible = isVisible end
            if element.Frame then element.Frame.Visible = isVisible end
            if element.Base then element.Base.Visible = isVisible end
            
            -- บังคับเซตค่า Visible ลงใน Table ด้วย (ถ้า Library รองรับ Setter)
            element.Visible = isVisible 
            if type(element.SetVisible) == "function" then element:SetVisible(isVisible) end
        elseif typeof(element) == "Instance" then
            element.Visible = isVisible
        end
    end)
end

