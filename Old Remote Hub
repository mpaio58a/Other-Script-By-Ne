RunService.RenderStepped:Connect(function()
    if Toggles.PlayerESP and Toggles.PlayerESP.Value then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                local char = p.Character
                local head = char and char:FindFirstChild("Head")
                local hum = char and char:FindFirstChild("Humanoid")

                if char and head and hum and hum.Health > 0 then
                    local hl = char:FindFirstChild("ESPHighlight")
                    if not hl then
                        hl = Instance.new("Highlight", char)
                        hl.Name = "ESPHighlight"
                        hl.FillColor, hl.OutlineColor = Color3.new(1, 1, 1), Color3.new(1, 1, 1)
                        hl.FillTransparency, hl.OutlineTransparency = 0.5, 0
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    end
                    hl.Adornee = char

                    local bb = espFolder:FindFirstChild(p.Name .. "_ESP")
                    if not bb then
                        bb = Instance.new("BillboardGui", espFolder)
                        bb.Name = p.Name .. "_ESP"
                        bb.Size, bb.StudsOffset, bb.AlwaysOnTop = UDim2.new(0, 100, 0, 40), Vector3.new(0, 3.5, 0), true
                        local lbl = Instance.new("TextLabel", bb)
                        lbl.Name, lbl.Size = "Label", UDim2.new(1, 0, 1, 0)
                        lbl.BackgroundTransparency, lbl.TextColor3 = 1, Color3.new(1, 1, 1)
                        lbl.Font, lbl.TextSize = Enum.Font.SourceSansBold, 14
                    end

                    if bb.Adornee ~= head then bb.Adornee = head end
                    bb.Label.Text = p.Name .. "\n" .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
                else
                    local bb = espFolder:FindFirstChild(p.Name .. "_ESP")
                    if bb then bb.Adornee = nil bb.Label.Text = "" end
                end
            end
        end
    end

    if Toggles.AimbotToggle and Toggles.AimbotToggle.Value and targetPlayer then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tRoot = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local tHum = targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid")
        if myRoot and tRoot and tHum and tHum.Health > 0 then
            myRoot.CFrame = CFrame.lookAt(myRoot.Position, Vector3.new(tRoot.Position.X, myRoot.Position.Y, tRoot.Position.Z))
        elseif tHum and tHum.Health <= 0 then
            Toggles.AimbotToggle:SetValue(false)
        end
    end
end)

