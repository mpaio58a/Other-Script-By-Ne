local function MakeDraggable(guiObject)
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        guiObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = guiObject.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

local function createOnScreenButton(remote, remoteDisplayName, buttonText)
    local guiName = "CustomRemoteButtonsGui"
    local gui = CoreGui:FindFirstChild(guiName) or Instance.new("ScreenGui", CoreGui)
    gui.Name = guiName

    local randomId = math.random(1, 100000)
    local btn = Instance.new("TextButton")
    btn.Name = remote.Name .. "_" .. randomId
    btn.Text = "  " .. buttonText .. "  "
    btn.Size = UDim2.new(0, 0, 0, 25)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Position = UDim2.new(0, math.random(50, 250), 0, math.random(50, 250))
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.Parent = gui
    MakeDraggable(btn)

    btn.MouseButton1Click:Connect(function()
        local amount = tonumber(savedAmounts[remoteDisplayName]) or 1
        for i = 1, amount do remote:FireServer() end
    end)
end

-- 1. เพิ่ม Dropdown Search และ ช่องค้นหาแบบตัวอักษรนำหน้า
local TopRemoteGroupbox = Tabs.Remote:AddLeftGroupbox("Search & Execute")

local remoteNames = {}
local remoteMap = {}

for _, instance in ipairs(ReplicatedStorage:GetDescendants()) do
    if instance:IsA("RemoteEvent") then
        local displayName = instance.Name .. " [" .. instance.Parent.Name .. "]"
        table.insert(remoteNames, displayName)
        remoteMap[displayName] = instance
        savedAmounts[displayName] = "1"
    end
end

if #remoteNames == 0 then
    table.insert(remoteNames, "No Remotes Found")
end

-- ช่องค้นหาที่สร้างใหม่ (กรองแบบ Starts With)
TopRemoteGroupbox:AddInput("SearchRemotePrefix", {
    Default = "",
    Numeric = false,
    Finished = false,
    Text = "Search Remote (Prefix)",
    Placeholder = "Search starting with...",
    Callback = function(Value)
        local term = string.lower(Value)
        local filtered = {}
        
        for _, name in ipairs(remoteNames) do
            -- เช็คว่าชื่อเริ่มต้นด้วยคำที่พิมพ์หรือไม่
            if term == "" or string.sub(string.lower(name), 1, #term) == term then
                table.insert(filtered, name)
            end
        end
        
        if #filtered == 0 then
            table.insert(filtered, "No Remotes Found")
        end
        
        -- อัปเดตรายการใน Dropdown
        if Options.SelectedRemote then
            Options.SelectedRemote:SetValues(filtered)
            Options.SelectedRemote:SetValue(filtered[1]) -- เลือกอันแรกอัตโนมัติ
        end
    end
})

TopRemoteGroupbox:AddDropdown("SelectedRemote", {
    Values = remoteNames,
    Default = 1,
    Multi = false,
    Text = "Select Remote",
    Searchable = false, -- ปิด Searchable ของเดิมทิ้ง
    Callback = function(Value)
        if Options.TopRunAmount and not isSyncing then
            isSyncing = true
            Options.TopRunAmount:SetValue(savedAmounts[Value] or "1")
            isSyncing = false
        end
    end
})

TopRemoteGroupbox:AddInput("TopRunAmount", {
    Default = "1",
    Numeric = true,
    Finished = false,
    Text = "Amount to Fire",
    Placeholder = "Enter amount...",
    Callback = function(Value)
        if isSyncing then return end
        
        local selectedName = Options.SelectedRemote.Value
        if selectedName and selectedName ~= "No Remotes Found" then
            savedAmounts[selectedName] = Value
            
            local remote = remoteMap[selectedName]
            if remote then
                local uniqueId = "RemoteInput_" .. remote:GetDebugId()
                if Options[uniqueId] and Options[uniqueId].Value ~= Value then
                    isSyncing = true
                    Options[uniqueId]:SetValue(Value)
                    isSyncing = false
                end
            end
        end
    end
})

TopRemoteGroupbox:AddButton({
    Text = "▶ Run Selected",
    Func = function()
        local selectedName = Options.SelectedRemote.Value
        local remote = remoteMap[selectedName]
        if remote then
            local amount = tonumber(savedAmounts[selectedName]) or 1
            for i = 1, amount do
                remote:FireServer()
            end
        end
    end
})

TopRemoteGroupbox:AddButton({
    Text = "🪟 Add Float Button",
    Func = function()
        local selectedName = Options.SelectedRemote.Value
        local remote = remoteMap[selectedName]
        if remote then
            createOnScreenButton(remote, selectedName, remote.Name)
        end
    end
})

-- 2. รายชื่อ Remote ทั้งหมดแบบแยก (ด้านล่าง)
local RemoteGroupbox = Tabs.Remote:AddLeftGroupbox("All Remotes (List)")

for _, instance in ipairs(ReplicatedStorage:GetDescendants()) do
    if instance:IsA("RemoteEvent") then
        local displayName = instance.Name .. " [" .. instance.Parent.Name .. "]"
        local uniqueId = "RemoteInput_" .. instance:GetDebugId()
        
        RemoteGroupbox:AddLabel("🎯 " .. instance.Name)
        RemoteGroupbox:AddInput(uniqueId, { 
            Default = "1", 
            Numeric = true, 
            Finished = false, 
            Text = "Amount to Fire", 
            Placeholder = "Enter amount...",
            Callback = function(Value)
                if isSyncing then return end
                
                savedAmounts[displayName] = Value
                
                if Options.SelectedRemote and Options.SelectedRemote.Value == displayName then
                    if Options.TopRunAmount and Options.TopRunAmount.Value ~= Value then
                        isSyncing = true
                        Options.TopRunAmount:SetValue(Value)
                        isSyncing = false
                    end
                end
            end
        })
        RemoteGroupbox:AddButton({ Text = "Execute", Func = function()
            local amount = tonumber(savedAmounts[displayName]) or 1
            for i = 1, amount do instance:FireServer() end
        end })
        RemoteGroupbox:AddButton({ Text = "Add Button On Screen", Func = function() createOnScreenButton(instance, displayName, instance.Name) end })
        RemoteGroupbox:AddDivider()
    end
end

