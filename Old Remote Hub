MiscGroupbox:AddInput("AimbotTarget", {
    Default = "", Numeric = false, Finished = false, Text = "Aimbot Target", Placeholder = "Name / ran",
    Callback = function(Value)
        if Value == "" then targetPlayer = nil return end
        local name = string.lower(string.match(Value, "^%s*(.-)%s*$"))
        if name == "ran" or name == "random" then
            local plys = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then table.insert(plys, p) end
            end
            if #plys > 0 then targetPlayer = plys[math.random(1, #plys)]; Options.AimbotTarget:SetValue(targetPlayer.Name) else targetPlayer = nil end
            return
        end
        
        -- ปรับ Aimbot Search ให้ค้นหาจากคำนำหน้า (Prefix) ด้วย
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and string.sub(string.lower(p.Name), 1, #name) == name then 
                targetPlayer = p 
                return 
            end
        end
        targetPlayer = nil
    end
})

MiscGroupbox:AddButton({ Text = "🎯 Random Target", Func = function() Options.AimbotTarget:SetValue("ran") end })
MiscGroupbox:AddToggle("AimbotToggle", { Text = "Enable Aimbot (Look At)", Default = false })

