-- สร้างปุ่ม Float แบบ Toggle วนลูป
local function createCustomFloatToggle(buttonText, argsTable, waitInputId)
    local guiName = "CustomFloatTogglesGui"
    local gui = CoreGui:FindFirstChild(guiName) or Instance.new("ScreenGui", CoreGui)
    gui.Name = guiName
    gui.Enabled = Toggles.ShowFloatToggleFeature and Toggles.ShowFloatToggleFeature.Value or false

    local btn = Instance.new("TextButton")
    btn.Name = buttonText .. "_Toggle_" .. math.random(1, 10000)
    btn.Text = "  " .. buttonText .. " [OFF]  " 
    btn.Size = UDim2.new(0, 0, 0, 25)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Position = UDim2.new(0, math.random(50, 250), 0, math.random(50, 250))
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0) 
    btn.TextColor3 = Color3.fromRGB(255, 255, 255) 
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.Parent = gui
    MakeDraggable(btn)

    local isToggled = false
    btn.MouseButton1Click:Connect(function()
        isToggled = not isToggled
        btn.Text = isToggled and ("  " .. buttonText .. " [ON]  ") or ("  " .. buttonText .. " [OFF]  ")
        btn.BackgroundColor3 = isToggled and Color3.fromRGB(0, 100, 0) or Color3.fromRGB(0, 0, 0) -- เปลี่ยนเป็นสีเขียวตอนเปิด

        if isToggled then
            task.spawn(function()
                while isToggled do
                    local waitTime = tonumber(Options[waitInputId] and Options[waitInputId].Value) or 1
                    local success_remote, remote = pcall(function()
                        return ReplicatedStorage:WaitForChild("Remotes", 2):WaitForChild("Red", 2)
                    end)
                    
                    if success_remote and remote then
                        for i = 1, 50 do
                            remote:FireServer(unpack(argsTable))
                        end
                    end
                    task.wait(waitTime)
                end
            end)
        end
    end)
end

