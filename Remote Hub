local function addGlobalRemoteToUI(instance)
    if not instance or not instance:IsA("RemoteEvent") then return end
    if addedGlobalRemotes[instance] then return end
    addedGlobalRemotes[instance] = true
    generateRemoteUI(instance, RemoteGroupbox, globalRemoteElements, nil, "G_")
end

