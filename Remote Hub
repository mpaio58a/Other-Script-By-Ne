-- ฟังก์ชันกลางสำหรับสร้าง UI ของ Remote ลงใน Groupbox ไหนก็ได้
local function generateRemoteUI(instance, groupbox, trackingTable, uiRegistryTable, prefix)
    local labelId = prefix .. "RemoteLabel_" .. instance:GetDebugId() .. math.random(1000, 9999)
    local uniqueId = prefix .. "RemoteInput_" .. instance:GetDebugId() .. math.random(1000, 9999)
    local delayId = prefix .. "RemoteDelay_" .. instance:GetDebugId() .. math.random(1000, 9999)
    local divId = prefix .. "Div_" .. math.random(100000, 999999)
    
    pcall(function()
        local remoteLabel = groupbox:AddLabel(labelId, { Text = getRemotePathText(instance) })
        local inputAmt = groupbox:AddInput(uniqueId, { Default = "1", Numeric = true, Finished = false, Text = "Amount to Fire", Placeholder = "Enter amount..." })
        
        local btnExec = groupbox:AddButton({ Text = "Execute", Func = function()
            local amount = tonumber(Options[uniqueId].Value) or 1
            for i = 1, amount do pcall(function() instance:FireServer() end) end
        end })
        
        local btnFloat = groupbox:AddButton({ Text = "Add Button On Screen", Func = function() createOnScreenButton(instance, uniqueId, instance.Name) end })
        
        local inputDelay = groupbox:AddInput(delayId, { Default = "0.1", Numeric = true, Finished = false, Text = "Spam Delay (Speed)", Placeholder = "ยิ่งน้อยยิ่งเร็ว (เช่น 0.05)" })
        
        local spamBtn = groupbox:AddButton({ Text = "Add Float Toggle Button", Func = function() createOnScreenToggleButton(instance, delayId, instance.Name) end })
        
        if Toggles.HideSpamUI and Toggles.HideSpamUI.Value then
            Options[delayId]:SetVisible(false)
            spamBtn:SetVisible(false)
        end
        
        -- ใช้ Label จำลองเป็นเส้นคั่นแทน Divider เพราะลบง่ายกว่า
        local divLabel = groupbox:AddLabel(divId, { Text = "▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬▬" })
        
        -- บันทึกข้อมูลเพื่อใช้กับ Setting
        table.insert(trackingTable, {
            instance = instance,
            labelObj = remoteLabel,
            delayId = delayId,
            spamBtn = spamBtn
        })

        -- บันทึกข้อมูลเข้า Registry เพื่อใช้ "ซ่อน/ลบ" UI เวลารีเฟรช
        if uiRegistryTable then
            table.insert(uiRegistryTable, {type="Option", id=labelId})
            table.insert(uiRegistryTable, {type="Option", id=uniqueId})
            table.insert(uiRegistryTable, {type="Button", obj=btnExec})
            table.insert(uiRegistryTable, {type="Button", obj=btnFloat})
            table.insert(uiRegistryTable, {type="Option", id=delayId})
            table.insert(uiRegistryTable, {type="Button", obj=spamBtn})
            table.insert(uiRegistryTable, {type="Option", id=divId})
        end
    end)
end

