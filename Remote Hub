-- ======================================================================
-- [ HELPER FUNCTIONS: Smart Source Finder ]
-- ======================================================================
local function getFirstNodeName(inst)
    local current = inst.Parent
    if not current then return "Unknown" end
    
    local fallbackName = current.Name
    
    while current and current ~= game do
        if current:IsA("Tool") then
            return current.Name
        elseif current.Parent == game:GetService("Workspace") then
            return current.Name
        elseif current.Parent == game:GetService("ReplicatedStorage") then
            return current.Name
        elseif current.Parent and current.Parent:IsA("Player") then
            return current.Name
        end
        current = current.Parent
    end
    
    return fallbackName
end

local function getRemotePathText(instance)
    if Toggles.HideSource and Toggles.HideSource.Value then
        return "🎯 " .. instance.Name
    else
        local first = getFirstNodeName(instance)
        local last = instance.Name
        if first == last then
            return "🎯 " .. last
        else
            return "🎯 " .. first .. " ---> " .. last
        end
    end
end

