            if obj:IsA("RemoteEvent") and not addedGlobalRemotes[obj] then
                table.insert(newRemotes, obj)
            end
        end
        table.sort(newRemotes, function(a, b)
            local sourceA = getFirstNodeName(a):lower()
            local sourceB = getFirstNodeName(b):lower()
